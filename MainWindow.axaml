<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TVProgram.UI.ViewModels"
        xmlns:states="using:TVProgram.UI.States"
        xmlns:domain="using:TVProgram.Domain"
        x:Class="TVGuide.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Телепрограма"
        Width="800" Height="600"
        Background="#FFF9EE"
        Foreground="#1E1B13">

    <Window.KeyBindings>
        <KeyBinding Gesture="F1" Command="{Binding LoadChannelCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding EnterSelectionModeCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateNewShowCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}" />
    </Window.KeyBindings>

    <Panel Margin="20">
        <ContentControl Content="{Binding CurrentState}">
            <ContentControl.DataTemplates>

                <DataTemplate DataType="states:UIState+Home">
                    <StackPanel Spacing="15">
                        <TextBlock Text="📺 Розклад передач" FontSize="24" FontWeight="Bold" Foreground="#6D5E0F"/>
                        <ListBox ItemsSource="{Binding Channel.Shows}" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="domain:TVShow">
                                    <Border Background="#F4EDDF" Padding="15" CornerRadius="8" Margin="0,5">
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <TextBlock Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}" FontWeight="Bold" Foreground="#6D5E0F"/>
                                            <TextBlock Text="{Binding Title}" FontSize="16" Foreground="#1E1B13"/>
                                            <TextBlock Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"
                                                       VerticalAlignment="Center" Foreground="#4B4739"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </DataTemplate>

                <DataTemplate DataType="states:UIState+Selection">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Виберіть передачі для видалення" FontSize="20" Foreground="#BA1A1A"/>
                        <ListBox ItemsSource="{Binding Channel.Shows}" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="domain:TVShow">
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
                                        <CheckBox Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSelectionCommand}"
                                                  CommandParameter="{Binding Id}" />
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Foreground="#1E1B13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                            <Button Content="Підтвердити видалення" Background="#BA1A1A" Foreground="#FFFFFF"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfirmDeletionCommand}"/>
                            <Button Content="Скасувати (Esc)"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CancelCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>

                <DataTemplate DataType="states:UIState+Editor">
                    <Border Background="#F4EDDF" Padding="30" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="#CDC6B4" BorderThickness="1">
                        <StackPanel Spacing="15" Width="300">
                            <TextBlock Text="Редагування передачі" FontSize="20" FontWeight="Bold" Foreground="#6D5E0F" HorizontalAlignment="Center"/>

                            <TextBlock Text="Назва:" Foreground="#1E1B13"/>
                            <TextBox Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DraftTitle, Mode=TwoWay}" TabIndex="1"/>

                            <TextBlock Text="Тривалість:" Foreground="#1E1B13"/>
<NumericUpDown Value="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DraftDurationMinutes, Mode=TwoWay}" 
               Minimum="1" 
               Maximum="600" 
               Increment="5"
               FormatString="0"
               TabIndex="2"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                                <Button Content="Зберегти" Background="#6D5E0F" Foreground="#FFFFFF" TabIndex="3"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveCommand}"/>
                                <Button Content="Скасувати" TabIndex="4"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <DataTemplate DataType="states:UIState+Error">
                    <Border Background="#FFDAD6" Padding="30" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="#BA1A1A" BorderThickness="1">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Увага!" FontSize="24" FontWeight="Bold" Foreground="#BA1A1A"/>
                            <TextBlock Text="{Binding Message}" FontSize="16" TextWrapping="Wrap" MaxWidth="300" Foreground="#1E1B13"/>
                            <Button Content="Зрозуміло" HorizontalAlignment="Center" Margin="0,15,0,0"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DismissErrorCommand}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

            </ContentControl.DataTemplates>
        </ContentControl>
        
        <Button Command="{Binding CreateNewShowCommand}"
                Width="60" Height="60"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Background="#6D5E0F"
                Foreground="White"
                FontSize="30"
                Content="+"
                ToolTip.Tip="Додати нову передачу (Ctrl+N)">
            <Button.Styles>
                <Style Selector="Button">
                    <Setter Property="CornerRadius" Value="30"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
                <!-- Ефект при наведенні -->
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#8A792A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </Button.Styles>
        </Button>
        
    </Panel>
</Window>